{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "Host",
      "displayName": "Host",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/Host",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CUCUMBER_QUERY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "Coverage",
      "displayName": "Coverage",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/Coverage",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CUCUMBER_QUERY_BUILD_TESTS": "ON",
        "CUCUMBER_QUERY_ENABLE_COVERAGE": "ON"
      }
    },
    {
      "name": "Mutation",
      "displayName": "Mutation",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/Mutation",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang++",
        "CUCUMBER_QUERY_BUILD_TESTS": "ON",
        "CUCUMBER_QUERY_ENABLE_MUTATION": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Host",
      "configurePreset": "Host"
    },
    {
      "name": "Coverage",
      "configurePreset": "Coverage"
    },
    {
      "name": "Mutation",
      "configurePreset": "Mutation"
    }
  ],
  "testPresets": [
    {
      "name": "Coverage",
      "configurePreset": "Coverage",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    }
  ]
}
